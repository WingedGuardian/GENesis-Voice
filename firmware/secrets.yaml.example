# ESPHome Secrets Configuration
# 
# Copy this file to secrets.yaml and fill in your actual values
# secrets.yaml is ignored by git and should not be committed

# WiFi Configuration
wifi_ssid: "Your WiFi SSID"
wifi_password: "Your WiFi Password"  # pragma: allowlist secret

# Home Assistant API
api_encryption_key: "Your Home Assistant API encryption key"
# Get this from Home Assistant: Settings → Devices & Services → ESPHome → Add Device
# Or from an existing ESPHome device's configuration

# OTA Updates
ota_password: "Your OTA password"  # pragma: allowlist secret
# Choose a secure password for over-the-air updates

# Genesis Voice Bridge Addon Configuration
# WebSocket server URL for the Genesis Voice Bridge addon (conversational s2s)
server_url: "ws://192.168.1.10:8080"  # Format: ws://<HA_IP>:<PORT>
# Replace with your Home Assistant instance IP and addon port

# Ambient bridge URL (passive, wake-word-free capture — the ambient_bridge
# service on your Voice Edge box). Used only when the Ambient Mode switch is ON.
# Point at the ambient bridge's port (default 8765). If you don't use ambient
# capture, leave a placeholder here — nothing connects until the switch is ON.
ambient_bridge_url: "ws://192.168.1.10:8765"  # Format: ws://<EDGE_HOST>:<PORT>

# Active Listening control endpoint (the ambient bridge's HTTP /mode endpoint, default
# port 8767 on the same Voice Edge box). The "Active Listening" switch POSTs here to
# route this device's audio to the cloud (active) or back to the local model (passive).
listen_control_url: "http://192.168.1.10:8767/mode"  # Format: http://<EDGE_HOST>:<PORT>/mode

# Hey Genesis wake word model URL (hosted on HA's web server)
hey_genesis_model_url: "http://192.168.1.10:8123/local/wake_words/hey_genesis.json"

