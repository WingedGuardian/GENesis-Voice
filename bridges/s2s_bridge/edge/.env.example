# s2s bridge (edge deploy) — copy to .env and fill in. .env is gitignored.
# Required
OPENAI_API_KEY=

# Bridge listen port (the device connects here)
WEBSOCKET_PORT=8080

# Genesis box, reachable from the edge, + its HTTP bearer token
GENESIS_URL=
GENESIS_TOKEN=

# Turn detection eagerness for the open mic: low | medium | high
SEMANTIC_VAD_EAGERNESS=medium

# OpenAI Realtime spoken voice preset:
# alloy | ash | ballad | coral | echo | sage | shimmer | verse | cedar | marin
VOICE_S2S_VOICE=ash

# Reuse an idle session for this many seconds before starting fresh (0-3600)
SESSION_REUSE_TIMEOUT_SECONDS=300

# Record audio to disk for debugging (true/false)
ENABLE_RECORDING=false

# Noise gate — drop sub-threshold mic audio (peak int16 amplitude, 0-32767)
# to silence BEFORE OpenAI's VAD, so background noise/breath/wind doesn't
# trigger false interrupts. Real (louder) speech passes, so barge-in works.
# A higher bar applies while the bot is speaking. Calibrate on-device.
NOISE_GATE_OPEN_THRESHOLD=500
NOISE_GATE_BOT_SPEAKING_THRESHOLD=1500
# Keep the gate open this long after a loud frame so mid-word dips aren't clipped.
NOISE_GATE_HANGOVER_MS=250
# Onset guard: mute ALL mic input for this long after the bot starts speaking.
# The bot's own onset echo otherwise trips OpenAI's VAD into cutting the bot off
# ~0.5s in (and the cutoffs cascade). Echo and real barge-in overlap in amplitude,
# so only this time-based guard separates them; barge-in resumes after the window.
# Set to 0 to disable (restores instant barge-in during bot speech).
NOISE_GATE_BOT_ONSET_GUARD_MS=1500
# Diagnostic logging cadence (seconds) for calibration: the gate emits a sampled
# summary (pass/gate counts, max peaks) this often, plus a line when audio slips
# through while the bot is speaking. Set to 0 to turn the logging OFF once the
# thresholds are dialed in (no redeploy needed).
NOISE_GATE_LOG_INTERVAL_S=2.0

# End the session after this many seconds of GENUINE idle — no user speech,
# no bot speech, no pending tool call or response. The bridge owns this; the
# firmware's auto-stop is only a long backstop. (replaces the old 20s-from-bot-
# audio firmware timer that cut off long user turns)
IDLE_TIMEOUT_SECONDS=45
