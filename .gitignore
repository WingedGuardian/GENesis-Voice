# Secrets and local config — never commit
.env
*.env
!.env.example
secrets.yaml
secrets.env

# Local data + models
*.db
*.db-wal
*.db-shm
models/
*.onnx
*.wav
*.flac
*.pcm

# Voice enrollment / runtime artifacts — BIOMETRIC, never commit to a public repo
# (these default to ~/ outside the repo; ignored here as defense-in-depth so a voiceprint
#  can never be committed even if a path points into the tree or the bridge runs from here)
*speaker_registry*.json
ambient_speaker_registry.json
ambient_enroll_request.json
ambient_enroll_result.json
ambient_health.json
spike_audio*/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS / editor
.DS_Store
*.swp

# ESPHome build artifacts / cache (per-config .esphome dir — large, machine-specific)
.esphome/

# Android client (clients/android-mic) — build output, machine paths, signing + baked secrets
build/
.gradle/
local.properties
*.apk
*.aab
*.keystore
*.jks
.cxx/
# Per-build injected endpoint + token (BuildConfig). Only the .example is tracked.
secrets.properties
app/secrets.properties
