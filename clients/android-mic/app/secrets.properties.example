# Copy to app/secrets.properties (gitignored) and fill in your own values, OR pass the same
# keys as -P Gradle properties / MEETING_WS_URL + MEETING_TOKEN env vars at build time.
# These are baked into the APK's BuildConfig. NEVER commit the real values — the public repo
# only ever contains this .example with placeholders.

# Full WS base, ending in /meeting/  (the app appends the token)
meetingWsUrl=wss://your-host.tailnet-name.ts.net/meeting/

# The bridge's MEETING_INGEST_TOKEN (a long random string you set in ~/.meeting/meeting.env)
meetingToken=REPLACE_WITH_YOUR_TOKEN
