# Meeting bridge config — copy to ~/.meeting/meeting.env (chmod 600) and fill in.
# Loaded by deploy/systemd/meeting-bridge.service via EnvironmentFile. Never commit the real file.
#
# NOTE: systemd EnvironmentFile does NOT expand ~ or %h — use ABSOLUTE paths for any *_PATH/DIR
# you override. The built-in defaults expand ~ correctly at runtime, so leaving them unset is fine.

# --- auth (REQUIRED) ---
# The sole gate on the public Tailscale Funnel door. Treat it like a password: long + random,
# e.g. `openssl rand -hex 32`. Empty/unset => nothing authenticates (fail closed).
MEETING_INGEST_TOKEN=Replace-with-a-long-random-token

# Optional zero-downtime rotation: set the OLD token here while clients move to the new one.
# MEETING_INGEST_TOKEN_PREVIOUS=

# --- Speechmatics / diarization (optional overrides) ---
# By default the bridge REUSES the ambient bridge's existing key (~/.ambient-active/speechmatics.key).
# Override with an ABSOLUTE path only if you keep a separate key:
# MEETING_SM_KEY_PATH=/home/your-user/.ambient-active/speechmatics.key
# MEETING_MODEL=enhanced
# MEETING_MAX_SPEAKERS=          # blank = auto-detect (right for an unknown 1:1 / small meeting)
# Diarization is MEETING-tuned to segment more (multi-speaker rooms under-segment on the ambient
# bridge's near-field defaults). Tune per room if a real meeting over-splits (spurious speaker flips):
# MEETING_PREFER_CURRENT_SPEAKER=false   # true = stick with the current speaker at a boundary (less splitting)
# MEETING_SPEAKER_SENSITIVITY=0.6        # higher = split new speakers more readily; blank/none = Speechmatics default

# --- VAD-driven session lifecycle (optional) ---
# The bridge can gate on frame energy so it only opens/bills a Speechmatics session while someone is
# talking, finalizing after a silence — one transcript per meeting. OFF by default (threshold 0 =
# one session per connection, the legacy behavior). To calibrate: run with the gate OFF and read the
# `meeting vad[..] OFF(observe): ... max_peak=.. avg_peak=..` log lines to see the room's speech vs.
# silence peaks, then set the threshold between them and restart. Keep SILENCE_CLOSE_S below
# Speechmatics' real-time idle timeout.
# MEETING_VAD_THRESHOLD=0          # peak int16 amplitude for "speech"; 0 = gating off
# MEETING_SILENCE_CLOSE_S=45       # finalize a session after this many seconds of mic silence
# MEETING_VAD_HANGOVER_S=0.4       # keep forwarding this long after speech (don't clip word-tails)
# MEETING_VAD_LOG_INTERVAL_S=30    # calibration peak/pass/gate summary interval; 0 disables
# In a real room the mic is rarely silent (HVAC, distant talk), so the energy gate alone can keep a
# session open — and billing — long after the meeting's words stop. This closes on ASR-evidence silence
# instead (no non-empty partial or final), then stays dormant (no new session on mere noise) until the
# room is quiet / a marker / a reconnect. Partials count as evidence, so a quiet meeting the ASR hears
# but can't commit as finals stays open. Lower to trim the tail; raise if real meetings get split.
# MEETING_TRANSCRIPT_IDLE_CLOSE_S=300  # finalize after this long with no ASR speech evidence; 0 = off

# --- ingress (optional) ---
# MEETING_HTTP_PORT=8790         # loopback; the Tailscale Funnel maps a public 443/8443/10000 here
# MEETING_OUTPUT_DIR=/home/your-user/meeting-sessions
