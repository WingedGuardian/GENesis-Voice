# Meeting bridge config — copy to ~/.meeting/meeting.env (chmod 600) and fill in.
# Loaded by deploy/systemd/meeting-bridge.service via EnvironmentFile. Never commit the real file.
#
# NOTE: systemd EnvironmentFile does NOT expand ~ or %h — use ABSOLUTE paths for any *_PATH/DIR
# you override. The built-in defaults expand ~ correctly at runtime, so leaving them unset is fine.

# --- auth (REQUIRED) ---
# The sole gate on the public Tailscale Funnel door. Treat it like a password: long + random,
# e.g. `openssl rand -hex 32`. Empty/unset => nothing authenticates (fail closed).
MEETING_INGEST_TOKEN=Replace-with-a-long-random-token

# Optional zero-downtime rotation: set the OLD token here while clients move to the new one.
# MEETING_INGEST_TOKEN_PREVIOUS=

# --- Speechmatics / diarization (optional overrides) ---
# By default the bridge REUSES the ambient bridge's existing key (~/.ambient-active/speechmatics.key).
# Override with an ABSOLUTE path only if you keep a separate key:
# MEETING_SM_KEY_PATH=/home/your-user/.ambient-active/speechmatics.key
# MEETING_MODEL=enhanced
# MEETING_MAX_SPEAKERS=          # blank = auto-detect (right for an unknown 1:1 / small meeting)

# --- ingress (optional) ---
# MEETING_HTTP_PORT=8790         # loopback; the Tailscale Funnel maps a public 443/8443/10000 here
# MEETING_OUTPUT_DIR=/home/your-user/meeting-sessions
