# OMI bridge secrets/config — copy to ~/.omi/omi.env and fill in. NEVER commit real values.
# The systemd unit reads this via EnvironmentFile=-%h/.omi/omi.env.

# REQUIRED: a long random secret. It rides the webhook URL path (OMI can't send auth headers):
#   https://<your-funnel-host>/omi/<OMI_INGEST_SECRET_TOKEN>/ingest
# Generate one with: openssl rand -hex 32
OMI_INGEST_SECRET_TOKEN=replace-with-a-long-random-token

# Optional second factor: comma-separated OMI account uid(s) allowed to POST. Empty => the
# token alone gates (uid check skipped). Your uid is the ?uid= value OMI puts on the webhook.
OMI_UID_ALLOWLIST=

# Optional: set during a token rotation so the old token keeps working until OMI is updated.
# OMI_INGEST_SECRET_TOKEN_PREVIOUS=

# Optional overrides (defaults shown):
# OMI_HTTP_HOST=127.0.0.1
# OMI_HTTP_PORT=8788
# OMI_DB=~/ambient.db          # SHARED with the ambient bridge — same substrate, on purpose
# OMI_TTL_HOURS=48
